<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.app.pawamigo">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PawAmigo"
        tools:targetApi="31">

        <!-- Splash screen (Launches first) -->
        <activity
            android:name=".ui.onboarding.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.PawAmigo">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Authentication -->
        <activity
            android:name=".ui.onboarding.LoginActivity"
            android:exported="false" />

        <!-- Registration Flow -->
        <activity
            android:name=".ui.onboarding.OwnerRegistrationActivity"
            android:exported="false" />
        <activity
            android:name=".ui.onboarding.PetRegistrationActivity"
            android:exported="false" />
        <activity android:name=".community.CreatePostActivity"/>
        <activity android:name=".community.CommentsActivity"/>

        <activity
            android:name=".ui.onboarding.PreferenceActivity"
            android:exported="false" />
        <activity
            android:name=".ui.onboarding.PreferencesActivity"
            android:exported="false" />

        <!-- Dashboard (Home after login) -->
        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:exported="false" />
        <activity
            android:name=".ui.playdate.PlaydateActivity"
            android:exported="false" />


        <!-- Legacy / testing activity -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />



    </application>

</manifest>
