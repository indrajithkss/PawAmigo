<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/homepage"
    android:padding="16dp">

    <!-- 🔍 Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/search_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:layout_marginBottom="10dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_search" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:hint="Search nearby pets or parks..."
            android:textColorHint="@color/background_dark"
            android:textColor="@color/background_dark"
            android:background="@android:color/transparent"
            android:inputType="text" />
    </LinearLayout>

    <!-- 🧭 Filter Dropdown -->
    <Spinner
        android:id="@+id/spinnerFilter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:popupBackground="@color/background_dark"
        android:entries="@array/pet_filters"
        android:layout_marginBottom="12dp"
        android:textAlignment="center" />

    <!-- 🗺️ Map Placeholder -->
    <FrameLayout
        android:id="@+id/mapPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/map_placeholder_bg"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Map Placeholder (Google Map Integration Ready)"
            android:gravity="center"
            android:textColor="@color/gray_light"
            android:textSize="14sp" />
    </FrameLayout>

    <!-- 🐾 Nearby Pets Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nearby Pet Owners"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />



    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNearbyOwners"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:layout_marginTop="8dp"
        android:overScrollMode="never"/>
</LinearLayout>
