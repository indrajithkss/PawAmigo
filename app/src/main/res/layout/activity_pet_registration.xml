<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#033531"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Pet Image Upload -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/petProfileImage"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/ic_user"
            app:civ_border_width="3dp"
            app:civ_border_color="#FF6B6B"
            android:contentDescription="Pet Profile Image" />

        <Button
            android:id="@+id/btnUploadPetPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Pet Photo"
            android:textColor="@android:color/white"
            android:background="@drawable/rounded_button"
            android:layout_marginTop="10dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pet Registration"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tell us about your furry friend"
            android:textColor="#B0BEC5"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Pet Type -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pet Type:"
            android:textColor="#B0BEC5"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioGroupPetType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <RadioButton
                android:id="@+id/radioDog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dog"
                android:textColor="@android:color/white" />

            <RadioButton
                android:id="@+id/radioCat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cat"
                android:textColor="@android:color/white"
                android:layout_marginStart="24dp" />
        </RadioGroup>

        <!-- Pet Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Pet Name"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPetName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textColorHint="#B0BEC5" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pet Age -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Pet Age"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPetAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@android:color/white"
                android:textColorHint="#B0BEC5" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Breed -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Breed"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPetBreed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textColorHint="#B0BEC5" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Color -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Color"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPetColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textColorHint="#B0BEC5" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pet Size -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Size:"
            android:textColor="#B0BEC5"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <Spinner
            android:id="@+id/spinnerSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#B0BEC5"
            android:layout_marginBottom="10dp" />

        <!-- Gender -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gender:"
            android:textColor="#B0BEC5"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioGroupGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <RadioButton
                android:id="@+id/radioMale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Male"
                android:textColor="@android:color/white" />

            <RadioButton
                android:id="@+id/radioFemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Female"
                android:textColor="@android:color/white"
                android:layout_marginStart="24dp" />
        </RadioGroup>

        <!-- Vaccination -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vaccination Status:"
            android:textColor="#B0BEC5"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioGroupVaccination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <RadioButton
                android:id="@+id/radioVaccinated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vaccinated"
                android:textColor="@android:color/white" />

            <RadioButton
                android:id="@+id/radioNotVaccinated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not Vaccinated"
                android:textColor="@android:color/white"
                android:layout_marginStart="24dp" />
        </RadioGroup>

        <!-- Personality Traits -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Personality Traits:"
            android:textColor="#B0BEC5"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/checkboxFriendly"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Friendly"
            android:textColor="@android:color/white" />

        <CheckBox
            android:id="@+id/checkboxAggressive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aggressive"
            android:textColor="@android:color/white" />

        <CheckBox
            android:id="@+id/checkboxPlayful"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Playful"
            android:textColor="@android:color/white" />

        <!-- Continue Button -->
        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Continue"
            android:textColor="@android:color/white"
            android:background="@drawable/rounded_button"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="40dp"
            android:padding="14dp" />
        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textColor="@android:color/white"
            android:background="@drawable/rounded_button"
            android:layout_marginBottom="10dp"
            android:layout_gravity="start"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp" />
    </LinearLayout>
</ScrollView>
